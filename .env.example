# ============================================================
#  VILLAS CANGREJO — Variables de entorno (plantilla)
#  Copia este archivo como ".env" y rellena los valores reales.
#  El archivo .env NUNCA se sube a Git (está en .gitignore).
# ============================================================

# Puerto del servidor (en Render se define automáticamente)
PORT=3000

# Entorno: development | production
NODE_ENV=development

# ------------------------------------------------------------
# Base de datos MongoDB Atlas (OBLIGATORIA para persistencia real)
# Crea un cluster gratis en https://www.mongodb.com/atlas y pega aquí
# la cadena de conexión. Si la dejas vacía, se usa un MongoDB en memoria
# (los datos se pierden al reiniciar; solo para pruebas locales).
# Ejemplo:
# MONGODB_URI=mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/villas_cangrejo?retryWrites=true&w=majority
MONGODB_URI=

# ------------------------------------------------------------
# Credenciales del administrador.
# Se usan para crear el admin en el primer arranque (si no existe).
# ⚠ Elige una contraseña FUERTE y única (mínimo 8 caracteres).
ADMIN_USER=Angel Leonor
ADMIN_PASS=CAMBIA_ESTA_CONTRASENA

# ------------------------------------------------------------
# Envío de correos (recuperación de contraseña + avisos de reserva).
#
# OPCIÓN A — Brevo por API HTTPS (recomendada en Render: su plan Free
# bloquea SMTP). Cuenta gratis en https://www.brevo.com (300 correos/día);
# verifica el remitente y pega aquí la clave API. Si esta variable tiene
# valor, se usa Brevo y se ignora el SMTP de abajo.
BREVO_API_KEY=
#
# OPCIÓN B — SMTP (funciona en local). Para Gmail crea una "App Password":
# https://myaccount.google.com/apppasswords
# Si todo queda vacío, el sistema funciona en modo DEV (imprime el correo
# en la consola en lugar de enviarlo).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=Villas Cangrejo <no-reply@villascangrejo.mx>

# Correo del hotel que recibe los avisos de nuevas reservas
HOTEL_EMAIL=joseangel.hotel68@gmail.com
